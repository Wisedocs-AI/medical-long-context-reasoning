# Copy to `.env` and fill in. `.env` is gitignored.
# Loaded automatically by the CLI via python-dotenv before any provider is instantiated.

# ---------- Google / Vertex AI (Gemini) ----------
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS may be EITHER:
#   1) an absolute path to a service-account JSON file, e.g.
#      GOOGLE_APPLICATION_CREDENTIALS=/abs/path/sa.json
#   2) the JSON content of the service-account key, inline on one line, e.g.
#      GOOGLE_APPLICATION_CREDENTIALS={"type":"service_account","project_id":"…",...}
GOOGLE_APPLICATION_CREDENTIALS=
# Optional, defaults to us-central1
# GOOGLE_CLOUD_LOCATION=global

# ---------- Anthropic / AWS Bedrock (Claude) ----------
AWS_PROFILE=dev
# Optional region override; otherwise reads ~/.aws/config for the profile.
# AWS_REGION=us-east-1

# ---------- OpenAI / Azure OpenAI (GPT) ----------
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
